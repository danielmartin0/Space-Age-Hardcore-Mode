# Ignore everything by default
*

# Allow all directories (so we can whitelist specific ones)
!*/

# Whitelist config files and VSCode settings
!.gitignore
!.luacheckrc
!.prettierrc
!.styluaignore
!.vscode/
!.vscode/**

# Whitelist specific mods
!/Space-Age-Hardcore-Mode/**
!/Rocs-Hardcore-Cargo-Drops/**
!/Rocs-Hardcore-Delayed-Tech-Tree/**
!/Rocs-Hardcore-Demolishers/**
!/Rocs-Hardcore-Fulgora/**
!/Rocs-Hardcore-Gleba/**
!/Rocs-Hardcore-Aquilo/**
!/Rocs-Hardcore-Space-Tweaks/**
!/Rocs-Improved-Platform-Drag/**
!/Planetary-Distance-Adjustments/**
!/Expensive-Mode/**
!/Better-Melting-Ice/**
!/Planet-Hopper/**
!/Tiered-Solar-System/**
!/Space-Age-Without-Platforms/**
!/pirate_ship/**

# Ignore submodules
/Cerys-Moon-of-Fulgora/
/PlanetsLib/
/Flare Stack/
/solarsystemplusplus/
/Small-Space-Age/
/Communion/
/Space-Age-Revamp/
/Space-Age-Without-Platforms/
/Redrawn-Space-Connections/